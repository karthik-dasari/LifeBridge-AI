rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Hospitals collection
    match /hospitals/{hospitalId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['name', 'location', 'facilities', 'availability'])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 200;
      allow update: if request.auth != null
        && (!('name' in request.resource.data) || (request.resource.data.name is string && request.resource.data.name.size() <= 200));
      allow delete: if false;
    }

    // Alerts collection
    match /alerts/{alertId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['hospital_id', 'emergency_type', 'eta', 'timestamp'])
        && request.resource.data.hospital_id is string
        && request.resource.data.emergency_type is string;
      allow update, delete: if false;
    }

    // Live locations collection
    match /live_locations/{locationId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.data.keys().hasAll(['lat', 'lng', 'updated_at'])
        && request.resource.data.lat is number
        && request.resource.data.lng is number
        && request.resource.data.lat >= -90
        && request.resource.data.lat <= 90
        && request.resource.data.lng >= -180
        && request.resource.data.lng <= 180;
      allow delete: if false;
    }

    // Deny all other documents by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
